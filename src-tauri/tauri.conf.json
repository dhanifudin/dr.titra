{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "dr-titra",
  "version": "0.1.0",
  "identifier": "com.dhanifudin.dr-titra",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "dr.titra",
        "width": 360,
        "height": 540,
        "resizable": false,
        "alwaysOnTop": true,
        "decorations": false,
        "shadow": true,
        "visible": true,
        "center": false,
        "x": 50,
        "y": 50
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
